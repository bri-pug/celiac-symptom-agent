# Pylint configuration.
#
# The disabled checks below are deliberate design choices, not lint we're
# papering over — each is documented so a reviewer can see the intent:
#
#   missing-class-docstring        pydantic models in schemas.py are declarative
#                                  and self-documented by field names + comments.
#   too-many-arguments /           process_day exposes `client` and
#   too-many-positional-arguments  `ask_user_handler` for dependency injection so
#                                  the agent loop is testable without the network.
#   too-many-locals                run_tool is a small tool dispatcher; splitting
#                                  its branches would hurt readability, not help.
#   inconsistent-return-statements _create_with_retry either returns a response
#                                  or raises on the final attempt; the implicit
#                                  fall-through is unreachable by construction.

[MESSAGES CONTROL]
disable =
    missing-class-docstring,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-locals,
    inconsistent-return-statements

[FORMAT]
max-line-length = 100
